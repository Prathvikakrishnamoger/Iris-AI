# IrisAI Backend — Environment Variables
# Copy this to .env and fill in your real keys

# Google Gemini (get keys at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY_2=your_backup_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Twilio SMS Alerts (https://console.twilio.com)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
EMERGENCY_CONTACT=+91XXXXXXXXXX
USER_NAME=Patient

# Security
ENCRYPTION_PASSPHRASE=change_this_to_a_strong_passphrase

# YOLO
YOLO_MODEL_PATH=yolo11n.pt
YOLO_CONFIDENCE=0.5

# Server
PORT=8000
